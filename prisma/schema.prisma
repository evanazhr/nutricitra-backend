// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  fullname  String
  password  String
  avatarUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authentications Authentication[]
  predictLogs     PredictLog[]
  profile         Profile?
  meals            Meal[]

  @@map("users")
}

model Authentication {
  id     String @id @default(cuid())
  token  String @unique @db.Text
  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("authentications")
}

model PredictLog {
  id     String @id @default(cuid())
  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  food_name       String
  image_url       String @db.Text
  confident_score Float
  protein         Float
  calorie         Float
  fat             Float
  carbohydrate    Float
  
  portion         Float  @default(1.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  meals     Meal[]

  @@map("predict_logs")
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  height Float
  weight Float
  age    Int
  gender String

  calorieTarget      Float
  proteinTarget      Float
  carbohydrateTarget Float
  fatTarget          Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

model Meal {
  id           String  @id @default(cuid())
  userId       String

  // Optional karena bisa saja meal dibuat tanpa melalui proses prediksi, misalnya user ingin menambahkan makanan secara manual
  predictLogId String?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  predictLog PredictLog? @relation(fields: [predictLogId], references: [id], onDelete: SetNull)

  mealType MealType @default(BREAKFAST)
  portion  Float    @default(1.0)

  food_name       String
  image_url       String @db.Text
  confident_score Float?
  protein         Float
  calorie         Float
  fat             Float
  carbohydrate    Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 

  @@map("meals")
}

model FoodDictionary {
  id                  String  @id @default(cuid())
  foodName            String  @unique  @map("food_name")
  servingDescription  String? @map("serving_description")
  servingSizeG        Float?  @map("serving_size_g")
  fat                 Float
  calorie             Float   
  protein             Float
  carbohydrate        Float
  water               Float? @map("water")
  fiber               Float? @map("fiber")
  labelCategory       String? @map("label_category")
  originRegion        String? @map("origin_region")

  @@map("food_dictionaries")
}