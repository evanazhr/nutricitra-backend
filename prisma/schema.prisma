// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  fullname  String
  password  String
  avatarUrl String? @map("avatar_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authentications Authentication[]
  predictLogs     PredictLog[]
  profile         Profile?
  meals           Meal[]

  @@map("users")
}

model Authentication {
  id     String @id @default(cuid())
  token  String @unique @db.Text
  userId String @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("authentications")
}

model PredictLog {
  id     String @id @default(cuid())
  userId String @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  foodName       String  @map("food_name")
  imageUrl       String  @map("image_url") @db.Text
  confidentScore Float   @map("confident_score")
  protein        Float
  calorie        Float
  fat            Float
  carbohydrate   Float
  water          Float?  @map("water")
  fiber          Float?  @map("fiber")
  labelCategory  String? @map("label_category")
  originRegion   String? @map("origin_region")

  totalProtein      Float  @map("total_protein")
  totalCalorie      Float  @map("total_calorie")
  totalFat          Float  @map("total_fat")
  totalCarbohydrate Float  @map("total_carbohydrate")
  totalWater        Float? @map("total_water")
  totalFiber        Float? @map("total_fiber")

  portion Float @default(1.0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  meals     Meal[]

  @@map("predict_logs")
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  height Float
  weight Float
  age    Int
  gender String

  calorieTarget      Float @map("calorie_target")
  proteinTarget      Float @map("protein_target")
  carbohydrateTarget Float @map("carbohydrate_target")
  fatTarget          Float @map("fat_target")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model Meal {
  id     String @id @default(cuid())
  userId String @map("user_id")

  // Optional karena bisa saja meal dibuat tanpa melalui proses prediksi, misalnya user ingin menambahkan makanan secara manual
  predictLogId String? @map("predict_log_id")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  predictLog PredictLog? @relation(fields: [predictLogId], references: [id], onDelete: SetNull)

  foodName       String  @map("food_name")
  imageUrl       String? @map("image_url")
  confidentScore Float?  @map("confident_score")

  mealType String? @map("meal_type")
  portion  Float   @default(1.0)

  protein       Float
  calorie       Float
  fat           Float
  carbohydrate  Float
  water         Float?  @map("water")
  fiber         Float?  @map("fiber")
  labelCategory String? @map("label_category")
  originRegion  String? @map("origin_region")

  totalProtein      Float  @map("total_protein")
  totalCalorie      Float  @map("total_calorie")
  totalFat          Float  @map("total_fat")
  totalCarbohydrate Float  @map("total_carbohydrate")
  totalWater        Float? @map("total_water")
  totalFiber        Float? @map("total_fiber")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("meals")
}

model FoodDictionary {
  id                 String  @id @default(cuid())
  foodName           String  @unique @map("food_name")
  servingDescription String? @map("serving_description")
  servingSizeG       Float?  @map("serving_size_g")
  fat                Float
  calorie            Float
  protein            Float
  carbohydrate       Float
  water              Float?  @map("water")
  fiber              Float?  @map("fiber")
  labelCategory      String? @map("label_category")
  originRegion       String? @map("origin_region")

  @@map("food_dictionaries")
}
